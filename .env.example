# ============================================================
# Intelligent Loan Disbursement System — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=loan_db
POSTGRES_USER=loan_user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://loan_user:changeme@postgres:5432/loan_db

# ── Redis ────────────────────────────────────────────────────
# DB0 — Redis Streams (inter-service event bus)
REDIS_STREAMS_URL=redis://redis:6379/0
# DB1 — Celery broker + backend
REDIS_CELERY_URL=redis://redis:6379/1
# DB2 — Application cache
REDIS_CACHE_URL=redis://redis:6379/2

# ── JWT / Auth ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Twilio (SMS / WhatsApp) ──────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── SendGrid (Email) ─────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@loanservice.example.com
SENDGRID_FROM_NAME=Loan Disbursement System

# ── Google Document AI ───────────────────────────────────────
GOOGLE_DOC_AI_PROJECT=your-gcp-project-id
GOOGLE_DOC_AI_LOCATION=us
GOOGLE_DOC_AI_PROCESSOR_ID=your-processor-id
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-service-account.json

# ── Service URLs (internal) ──────────────────────────────────
BACKEND_API_URL=http://backend-api:8000
AGENT_SERVICE_URL=http://agent-service:8001
NOTIFICATION_SERVICE_URL=http://notification-service:8002

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000

# ── Application Settings ─────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
# Loan amount threshold (INR) above which HITL is triggered
HITL_THRESHOLD=1000000
# Max retries for disbursement Celery task
DISBURSEMENT_MAX_RETRIES=4

# ── pgvector / RAG ───────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RAG_COLLECTION_NAME=compliance_policies

# ── File Storage ─────────────────────────────────────────────
# local | s3
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-south-1
